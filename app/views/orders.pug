doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title QuickShop | Orders
    link(rel="stylesheet" href="/style.css")
  body
    include products-navbar.pug

    section.cart-page
      .cart-content
        h2 Your Orders
        p Review your recent purchases and delivery details.

        if orders.length
          .orders-list
            each order in orders
              article.order-card
                .order-card-header
                  div
                    h3 Order ##{order.order_id}
                    p.order-meta Placed on #{new Date(order.created_at).toLocaleDateString()}
                  .order-badge= order.status_name || "Pending"

                .order-summary
                  .summary-row
                    span Items
                    strong= order.item_count
                  .summary-row
                    span Total
                    strong £#{Number(order.total_amount || 0).toFixed(2)}

                .order-address
                  strong Delivery Address
                  p #{order.street}, #{order.city}, #{order.state}, #{order.postal_code}, #{order.country}

                if order.items.length
                  .order-items
                    each item in order.items
                      .order-item
                        if item.image_url
                          img.order-item-image(src=item.image_url alt=item.name)
                        else
                          .order-item-image.cart-item-image-empty
                        .order-item-details
                          a.product-link(href=`/products/${item.product_id}`)= item.name
                          span Qty #{item.quantity}
                        strong £#{Number(item.price).toFixed(2)}
        else
          .products-empty
            h3 No orders yet
            p Once you complete checkout, your orders will appear here.
            a.primary-action(href="/products") Start Shopping

    footer
      p © 2026 QuickShop. All rights reserved.
