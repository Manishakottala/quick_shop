doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title QuickShop | Retailer Products
    link(rel="stylesheet" href="/style.css")
  body
    include products-navbar.pug

    section.retailer-dashboard
      .retailer-dashboard-content
        .dashboard-hero
          .page-title-row
            h2 Products
            a.primary-action(href="/retailer/products?create=1") Create

        if authError
          p.auth-message.auth-message-error= authError
        if authSuccess
          p.auth-message.auth-message-success= authSuccess

        .retailer-products-toolbar
          form.retailer-products-filters(action="/retailer/products" method="get")
            .filter-field.filter-search
              label(for="search") Search
              input#search(type="search" name="search" placeholder="Search products" value=filters.search)

            .filter-field
              label(for="status") Status
              .filter-select-wrap
                select#status.filter-select(name="status")
                  option(value="") All
                  option(value="active" selected=filters.status === "active") Active
                  option(value="inactive" selected=filters.status === "inactive") Inactive

            .filter-field
              label(for="store_id") Store
              .filter-select-wrap
                select#store_id.filter-select(name="store_id")
                  option(value="") All
                  each store in stores
                    option(value=store.store_id selected=String(filters.store_id) === String(store.store_id))= store.store_name

            .filter-field
              label(for="category_id") Category
              .filter-select-wrap
                select#category_id.filter-select(name="category_id")
                  option(value="") All
                  each category in categories
                    option(value=category.category_id selected=String(filters.category_id) === String(category.category_id))= category.name

            .filter-actions
              button.filter-button(type="submit") Search
              a.clear-filters(href="/retailer/products") Reset

        if (createMode || editProduct) && categories.length && stores.length
          .retailer-panel.retailer-form-panel
            h3= editProduct ? "Edit Product" : "Create Product"
            form.retailer-form(action=editProduct ? `/retailer/products/${editProduct.product_id}/update` : "/retailer/products" method="post")
              .form-group
                label(for="name") Product Name
                input#name(type="text" name="name" required value=editProduct ? editProduct.name : "")

              .form-group
                label(for="description") Description
                textarea#description(name="description" rows="4")= editProduct ? editProduct.description : ""

              .form-row
                .form-group
                  label(for="price") Price
                  input#price(type="number" name="price" min="0" step="0.01" required value=editProduct ? editProduct.price : "")
                .form-group
                  label(for="stock") Stock
                  input#stock(type="number" name="stock" min="0" step="1" required value=editProduct ? editProduct.stock : "")

              .form-row
                .form-group
                  label(for="category_id_form") Category
                  .form-select-wrap
                    select#category_id_form.form-select(name="category_id" required)
                      option(value="") Select a category
                      each category in categories
                        option(value=category.category_id selected=editProduct && Number(editProduct.category_id) === Number(category.category_id))= category.name
                .form-group
                  label(for="store_id_form") Store
                  .form-select-wrap
                    select#store_id_form.form-select(name="store_id" required)
                      each store in stores
                        option(value=store.store_id selected=editProduct ? Number(editProduct.store_id) === Number(store.store_id) : false)= store.store_name

              .form-row
                .form-group
                  label(for="status_form") Status
                  .form-select-wrap
                    select#status_form.form-select(name="status" required)
                      option(value="active" selected=!editProduct || editProduct.status === "active") Active
                      option(value="inactive" selected=editProduct && editProduct.status === "inactive") Inactive
                .form-group
                  label(for="image_url") Image URL
                  input#image_url(type="url" name="image_url" placeholder="https://example.com/image.jpg" value=editProduct ? editProduct.image_url : "")

              .retailer-form-actions
                button.primary-action(type="submit")= editProduct ? "Update" : "Create"
                a.secondary-action(href="/retailer/products") Cancel

        if !categories.length
          .dashboard-empty
            h3 Categories required
            p Add categories before creating products.

        if products.length
          .dashboard-table-wrap
            table.dashboard-table.retailer-products-table
              thead
                tr
                  th Product
                  th Store
                  th Category
                  th Price
                  th Stock
                  th Status
                  th.actions-cell Actions
              tbody
                each product in products
                  tr
                    td
                      .table-product
                        if product.image_url
                          img.table-product-image(src=product.image_url alt=product.name)
                        else
                          .table-product-image.table-product-image-empty
                        .table-product-copy
                          strong= product.name
                          if product.description
                            span= product.description
                    td= product.store_name
                    td= product.category_name || "-"
                    td £#{Number(product.price || 0).toFixed(2)}
                    td= product.stock
                    td
                      span(class=`status-pill status-${product.status}`)= product.status
                    td.actions-cell
                      .row-actions
                        a.icon-action.edit-action(href=`/retailer/products?edit=${product.product_id}` title="Edit" aria-label="Edit") ✎
                        form(action=`/retailer/products/${product.product_id}/delete` method="post")
                          button.icon-action.delete-action(type="submit" title="Delete" aria-label="Delete") 🗑
        else
          .dashboard-empty
            h3 No products
            p No products match the current filter.

    footer
      p © 2026 QuickShop. All rights reserved.
