doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    title QuickShop | Register
    link(rel="stylesheet" href="/style.css")
  body
    include navbar.pug

    section.auth-page
      .auth-card
        h2 Create Account
        p.auth-text Register to track orders, save products, and shop faster on your next visit.

        if authError
          p.auth-message.auth-message-error= authError

        form.auth-form(action="/register" method="post")
          .form-group
            label(for="name") Full Name
            input#name(type="text" name="name" placeholder="Enter your full name" required)

          .form-group
            label(for="email") Email Address
            input#email(type="email" name="email" placeholder="you@example.com" required)

          .form-group
            label(for="phone") Phone Number
            input#phone(type="tel" name="phone" placeholder="Enter your phone number")

          .form-group
            span.form-label Role
            .role-options
              label.role-option
                input(type="radio" name="role" value="customer" checked required)
                span.role-option-title Customer
                span.role-option-text Shop products and place orders
              label.role-option
                input(type="radio" name="role" value="retailer" required)
                span.role-option-title Retailer
                span.role-option-text Manage listings and sell products

          .form-group
            label(for="password") Password
            input#password(type="password" name="password" placeholder="Create a password" required)

          .form-group
            label(for="confirmPassword") Confirm Password
            input#confirmPassword(type="password" name="confirmPassword" placeholder="Repeat your password" required)

          button(type="submit") Register

        p.auth-switch
          | Already have an account?
          a(href="/login") Sign in

    footer
      p © 2026 QuickShop. All rights reserved.
